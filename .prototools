# Proto toolchain configuration for RAG Facile
# This file pins versions of all tools used in the project
# See: https://moonrepo.dev/docs/proto

python = "3.13"

# Plugins for non-core tools
[plugins]
just = "source:https://raw.githubusercontent.com/moonrepo/proto-toml-plugins/master/plugins/just.toml"

# Tool-specific versions
[tools.just]
version = "1.34.0"
